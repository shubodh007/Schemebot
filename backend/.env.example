# ═══════════════════════════════════════════════════════════════
# GOVSCHEME AI — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── General ───────────────────────────────────────────────────
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=                          # 64-char hex: openssl rand -hex 64
API_V1_PREFIX=/v1                   # API version prefix
CORS_ORIGINS=http://localhost:3000   # Comma-separated allowed origins

# ── Supabase (DB + Auth + Storage) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=                   # Public anon key (frontend-safe)
SUPABASE_SERVICE_ROLE_KEY=           # Secret service role key (backend only)
SUPABASE_DB_URL=postgresql+asyncpg://postgres:password@aws-0.ap-south-1.rds.amazonaws.com:5432/postgres
# Note: Use transaction pooler URL from Supabase dashboard for production

# ── Upstash Redis (Cache + Queue) ─────────────────────────────
UPSTASH_REDIS_URL=redis://default:password@apt-marmot-12345.upstash.io:6379
UPSTASH_REDIS_TOKEN=                 # Upstash REST API token (for management)

# ── OpenRouter (Multi-Model AI Provider) ──────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://govscheme.in  # For rankings on OpenRouter leaderboard
OPENROUTER_SITE_NAME=GovScheme AI

# ── Google AI (Embeddings + Fallback LLM) ─────────────────────
GOOGLE_AI_API_KEY=                   # From Google AI Studio (free tier)
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# ── Anthropic (Optional: direct API fallback) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...         # Optional, only if using Claude directly

# ── OpenAI (Optional: direct API fallback) ────────────────────
OPENAI_API_KEY=sk-proj-...           # Optional, only if using GPT directly

# ── DeepSeek (Optional: direct API fallback) ──────────────────
DEEPSEEK_API_KEY=sk-...              # Optional

# ── Groq (Optional: direct API fallback) ─────────────────────
GROQ_API_KEY=gsk_...                 # Optional

# ── Sentry (Error Tracking) ───────────────────────────────────
SENTRY_DSN=https://key@o123.ingest.sentry.io/123
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── PostHog (Product Analytics) ───────────────────────────────
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# ── Arq Worker (Background Jobs) ──────────────────────────────
ARQ_QUEUE_NAME=govscheme-tasks
ARQ_MAX_JOBS=10                      # Concurrent jobs per worker
ARQ_JOB_TIMEOUT=300                  # Seconds before job times out

# ── File Upload Limits ─────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_MAX=60            # Default requests per window
RATE_LIMIT_AUTH_MAX=10               # Auth endpoints per window
RATE_LIMIT_CHAT_MAX=20               # Chat streaming per window

# ── AI Provider Selection ─────────────────────────────────────
AI_PRIMARY_PROVIDER=openrouter       # openrouter | anthropic | google | openai
AI_FALLBACK_PROVIDER=openrouter      # Fallback if primary fails
AI_ELIGIBILITY_MODEL=anthropic/claude-sonnet-4-20250514
AI_LEGAL_MODEL=anthropic/claude-sonnet-4-20250514
AI_CHAT_MODEL=google/gemini-2.0-flash-lite-preview-02-05
AI_SEARCH_MODEL=groq/llama-3.1-70b-versatile
AI_CLASSIFIER_MODEL=groq/llama-3.1-70b-versatile
AI_DOCUMENT_MODEL=google/gemini-2.0-flash-001
